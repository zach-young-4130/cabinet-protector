# Copy this file to .env and fill in real values. .env is git-ignored.

PORT=3000

# Postgres — either a full connection string, or PGDATABASE alone (defaults to protect_vinyl)
# DATABASE_URL=postgres://user:pass@localhost:5432/protect_vinyl
PGDATABASE=protect_vinyl

# Stripe (test mode) — https://dashboard.stripe.com/test/apikeys
# Secret key stays server-side only. Coupons are created/managed in the Stripe
# Dashboard (Product catalog > Coupons + Promotion codes) and applied through
# Checkout Elements (`actions.applyPromotionCode`) — we only store the resulting
# discount on each paid order for record-keeping.
STRIPE_SECRET_KEY=sk_test_...

# Where Stripe redirects after redirect-based payment methods.
# Must include the {CHECKOUT_SESSION_ID} placeholder is appended by the server.
CHECKOUT_RETURN_URL=http://localhost:4200/checkout
